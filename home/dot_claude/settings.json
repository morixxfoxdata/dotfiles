{
  "permissions": {
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Bash(chmod 777 *)",
      "Read(id_rsa*)",
      "Read(id_ed25519*)",
      "Write(.env*)",
      "Read(~/.ssh/**)"
    ],
    "allow": [
      "Bash(uv run *)",
      "Bash(uv sync *)",
      "Bash(uv add *)",
      "Bash(git status)",
      "Bash(ruff *)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(chmod *)"
    ],
    "defaultMode": "plan"
  },
  "language": "japanese",
  "alwaysThinkingEnabled": true,
  "includeCoAuthoredBy": false
}
